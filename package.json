{
  "name": "finsight-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "type-check": "npx tsc --noEmit",
    "type-check:app": "npx tsc --noEmit --project tsconfig.app.json",
    "type-check:test": "npx tsc --noEmit --project tsconfig.test.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:monte-carlo": "node test-monte-carlo-integration.js",
    "test:monte-carlo-api": "chmod +x ./scripts/test-monte-carlo-api.sh && ./scripts/test-monte-carlo-api.sh",
    "test:direct-data-products": "chmod +x ./direct-data-product-test.js && ./direct-data-product-test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-popover": "^1.1.13",
    "@rdfjs/data-model": "^2.1.0",
    "@react-spring/web": "^10.0.0",
    "@tanstack/react-query": "^5.76.1",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.4",
    "@types/node": "^22.15.19",
    "@types/react": "^18.3.12",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.9.0",
    "clsx": "^2.1.1",
    "csv-parser": "^3.0.0",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "framer-motion": "^10.16.4",
    "ioredis": "^5.6.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.511.0",
    "n3": "^1.25.2",
    "next": "^15.3.2",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3",
    "uuid": "^11.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/node-fetch": "^2.6.12",
    "babel-jest": "^29.7.0",
    "critters": "^0.0.23",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.8.2",
    "ts-jest": "^29.3.4"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^15.3.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/pages/_app.tsx",
      "!src/pages/_document.tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
