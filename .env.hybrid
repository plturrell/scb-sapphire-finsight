# Hybrid deployment environment configuration
# For Vercel frontend + NVIDIA GPU-enabled backend

# NVIDIA API configuration
NVIDIA_API_KEY=your_api_key_here
NVIDIA_API_URL=https://api.nvidia.com/v1
NVIDIA_MODEL_ID=nvidia/research-llm-70b

# Backend configuration
GPU_BACKEND_URL=https://your-gpu-backend-url.com
USE_GPU_ACCELERATION=true

# Frontend configuration
NEXT_PUBLIC_API_URL=${GPU_BACKEND_URL}
NEXT_PUBLIC_USE_HYBRID_DEPLOYMENT=true

# Feature flags
NEXT_PUBLIC_ENABLE_MONTE_CARLO=true
NEXT_PUBLIC_ENABLE_REAL_TIME_UPDATES=true

# Authentication (if needed)
# API_AUTH_TOKEN=your_auth_token_here